# ============================================================
# AFRILAND INVEST — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# --- Supabase (OBLIGATOIRE) ---
# Supabase → Settings → API → Project URL
SUPABASE_URL=https://VOTRE_PROJET_ID.supabase.co

# Supabase → Settings → API → anon public
SUPABASE_ANON_KEY=eyJhbGci...

# Supabase → Settings → API → service_role secret
SUPABASE_SERVICE_KEY=eyJhbGci...

# --- JWT (OBLIGATOIRE) ---
JWT_SECRET=votre_secret_jwt_long_et_securise_ici

# --- App (optionnel) ---
PORT=3000
NODE_ENV=production
APP_URL=https://votre-domaine.com
