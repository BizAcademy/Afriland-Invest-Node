node_modules/
client/node_modules/
.env
*.log
.DS_Store

# Uploads — garder le dossier mais pas les fichiers médias
uploads/*.jpg
uploads/*.jpeg
uploads/*.png
uploads/*.gif
uploads/*.webp
!uploads/.gitkeep

# Le client est pré-buildé : client/dist/ est commité volontairement
# (pas de build nécessaire sur Plesk)
!client/dist/
!client/dist/**

# Cache disque (pays/opérateurs Afribapay) — régénéré au runtime
.cache/
